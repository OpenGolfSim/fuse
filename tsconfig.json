{
  "compilerOptions": {
    "types": ["vite/client"],
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationDir": "dist/types",
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/*"],
      "@opengolfsim/fuse": ["./src/index.ts"],
    }
  },
  "include": ["src", "examples"]
}